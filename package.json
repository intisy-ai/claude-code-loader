{
  "name": "claude-code-loader",
  "version": "1.4.1",
  "description": "TUI launcher and cc shell command for Claude Code.",
  "main": "dist/plugin.js",
  "type": "module",
  "license": "MIT",
  "author": "intisy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/intisy-ai/claude-code-loader.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "plugin",
    "launcher",
    "tui"
  ],
  "files": [
    "dist/",
    "core-loader/dist/",
    "core/dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "claudeHub": {
    "daemon": {
      "script": "dist/proxy.js",
      "runtime": "bun",
      "port": 34567,
      "healthCheckUrl": "http://127.0.0.1:34567/health"
    }
  },
  "scripts": {
    "build": "npx tsc --project core-loader/tsconfig.json && npx esbuild core/src/index.ts --bundle --platform=node --format=esm --outfile=core/dist/index.js && npx tsc && node build.mjs",
    "postbuild": "node dist/plugin.js readme",
    "prepublishOnly": "npm run build",
    "test": "npm run build && vitest run"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "@types/node": "^25.9.1",
    "plugin-updater": "^1.0.21",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
